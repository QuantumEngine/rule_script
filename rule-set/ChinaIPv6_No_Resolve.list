# NAME: 中国 IPv6 顶级骨干网与云厂商
# REPO: https://github.com/QuantumEngine
# UPDATED: 2026-03-16 11:00

# 🇨🇳 IPv6 中国顶级骨干网与基础电信运营商直连
IP-CIDR6,2408::/16,no-resolve  # 含中国联通（2408:8000::/20 等子段，/16 非独占）
IP-CIDR6,2409::/16,no-resolve  # 含中国移动（2409:8000::/20 等子段，/16 非独占）
IP-CIDR6,240A::/16,no-resolve  # 混合分配（含广电 CBN、铁通/移动、中石化等）
IP-CIDR6,240B::/16,no-resolve  # 混合分配（含国家信息中心/政务网等）
IP-CIDR6,240C::/16,no-resolve  # 混合分配（含教育网 CERNET 240C:C000::/20，/16 非独占）
IP-CIDR6,240D::/16,no-resolve  # 混合分配
IP-CIDR6,240E::/16,no-resolve  # 含中国电信（240E::/18，余段未分配）
IP-CIDR6,240F::/16,no-resolve  # 混合分配

# ☁️ 中国顶级云厂商专属 IPv6 骨干网直连
IP-CIDR6,2402:4e00::/32,no-resolve  # 腾讯云 Tencent Cloud（大陆）
IP-CIDR6,2400:3200::/32,no-resolve  # 阿里云 Alibaba Cloud（大陆）
IP-CIDR6,2400:da00::/32,no-resolve  # 百度云 Baidu Cloud（大陆）